# ARGUS — Environment Template
# Copy this to .env and fill in your values

# ── App ──────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=change-this-in-production

# ── Database ──────────────────────────────────────────────────────
# SQLite (dev/default)
DATABASE_URL=sqlite:///./argus.db

# PostgreSQL (production — uncomment and fill in)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/nexusveil

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Discord ───────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL_HERE

# ── Market Data APIs ──────────────────────────────────────────────
ALPHA_VANTAGE_KEY=your_key_here
POLYGON_KEY=your_key_here

# ── Schwab API ──────────────────────────────────────────────────────
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=http://localhost:8000/schwab/callback
SCHWAB_TOKENS_PATH=schwab_tokens.json
SCHWAB_PAPER_MODE=true
SCHWAB_RISK_PER_TRADE_USD=1000.0

# ── S3 Credit Gate ────────────────────────────────────────────────
FREE_TIER_DAILY_SCANS=3
PAID_TIER_DAILY_SCANS=100
CREDITS_PER_DEEP_SCAN=5
CREDITS_PER_REPLAY=10
CREDITS_PER_SWEEP=20

# ── ECHO FORGE Integration ────────────────────────────────────────
# URL of the running ECHO FORGE service.
# Leave empty to run ARGUS in standalone mode (no pattern memory).
# Local dev:  http://localhost:8001
# Docker:     http://echo-forge:8001
# Production: https://your-echo-forge-service.onrender.com
ECHO_FORGE_URL=

# Timeout in seconds before ARGUS gives up waiting for ECHO FORGE
ECHO_FORGE_TIMEOUT=15

# Echo confidence below this value → echo context is ignored entirely
ECHO_CONFIDENCE_THRESHOLD=0.5

# failure_risk_score above this value → ARGUS applies defensive positioning
ECHO_DEFENSIVE_RISK_THRESHOLD=0.6
